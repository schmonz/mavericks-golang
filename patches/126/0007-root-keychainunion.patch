
Add the platform-independent core of the keychain-union trust model:
buildKeychainUnionPool takes enumerated keychain entries (cert DER + effective
kSecTrustSettingsResult) plus CA-bundle paths and returns the anchor pool
(trusted keychain certs union bundle certs) and the distrust set (SHA-256 of
Deny'd certs) used for the verify-time veto. No build constraint, so it is
unit-testable on any platform; the darwin enumeration that feeds it is a
separate patch. All identifiers are unexported to avoid changing the standard
library's public API.

--- src/crypto/x509/root_keychainunion.go.orig	2026-07-06 03:21:11.000000000 +0000
+++ src/crypto/x509/root_keychainunion.go
@@ -0,0 +1,111 @@
+package x509
+
+import (
+	"crypto/sha256"
+	"os"
+	"strings"
+)
+
+// Effective keychain trust results, mirroring Apple's kSecTrustSettingsResult
+// (1=TrustRoot, 2=TrustAsRoot, 3=Deny, 4=Unspecified); 0 = no explicit setting,
+// which Apple treats as trust-as-root.
+const (
+	keychainUnionTrustRoot   = 1
+	keychainUnionTrustAsRoot = 2
+	keychainUnionTrustDeny   = 3
+	keychainUnionTrustUnspec = 4
+)
+
+// keychainUnionTrustEntry is one enumerated keychain certificate and its effective
+// trust result.
+type keychainUnionTrustEntry struct {
+	der    []byte
+	result int
+}
+
+func keychainUnionFingerprint(der []byte) [32]byte { return sha256.Sum256(der) }
+
+// buildKeychainUnionPool returns the anchor pool (trusted keychain certs ∪ bundle
+// certs) and the distrust set (SHA-256 of Deny'd keychain certs). A Deny'd cert
+// is excluded from anchors AND recorded for the verify-time veto (Task 6).
+func buildKeychainUnionPool(entries []keychainUnionTrustEntry, bundlePaths []string) (*CertPool, map[[32]byte]bool) {
+	pool := NewCertPool()
+	distrust := make(map[[32]byte]bool)
+	for _, e := range entries {
+		cert, err := ParseCertificate(e.der)
+		if err != nil {
+			continue // skip unparseable keychain entries
+		}
+		switch e.result {
+		case keychainUnionTrustDeny:
+			distrust[keychainUnionFingerprint(e.der)] = true
+		case keychainUnionTrustRoot, keychainUnionTrustAsRoot, 0:
+			pool.AddCert(cert)
+		case keychainUnionTrustUnspec:
+			// not an anchor on its own
+		}
+	}
+	for _, p := range bundlePaths {
+		if pem := keychainUnionReadBundle(p); pem != nil {
+			pool.AppendCertsFromPEM(pem)
+		}
+	}
+	return pool, distrust
+}
+
+func keychainUnionReadBundle(path string) []byte {
+	b, err := os.ReadFile(path)
+	if err != nil {
+		return nil
+	}
+	return b
+}
+
+// keychainUnionDistrusted holds SHA-256 fingerprints of keychain-distrusted certs,
+// populated on darwin by the WS1 init. nil on other platforms, which makes the
+// verify.go veto a no-op there.
+var keychainUnionDistrusted map[[32]byte]bool
+
+// keychainUnionFilterDistrusted drops any chain containing a distrusted cert.
+func keychainUnionFilterDistrusted(chains [][]*Certificate) [][]*Certificate {
+	var out [][]*Certificate
+	for _, chain := range chains {
+		bad := false
+		for _, cert := range chain {
+			if keychainUnionDistrusted[keychainUnionFingerprint(cert.Raw)] {
+				bad = true
+				break
+			}
+		}
+		if !bad {
+			out = append(out, chain)
+		}
+	}
+	return out
+}
+
+// keychainUnionResolveBundlePaths returns the CA-bundle files to load, honoring the
+// standard env overrides: SSL_CERT_FILE (a single path) replaces the default list;
+// SSL_CERT_DIR (colon-separated dirs) adds each directory's entries. The keychain is
+// unioned in separately by the caller, so this only shapes the file-based sources.
+func keychainUnionResolveBundlePaths(getenv func(string) string, readDirNames func(string) ([]string, error), defaults []string) []string {
+	files := defaults
+	if f := getenv("SSL_CERT_FILE"); f != "" {
+		files = []string{f}
+	}
+	if dirs := getenv("SSL_CERT_DIR"); dirs != "" {
+		for _, d := range strings.Split(dirs, ":") {
+			if d == "" {
+				continue
+			}
+			names, err := readDirNames(d)
+			if err != nil {
+				continue
+			}
+			for _, n := range names {
+				files = append(files, d+"/"+n) // AppendCertsFromPEM tolerates non-PEM entries
+			}
+		}
+	}
+	return files
+}
